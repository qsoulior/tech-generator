{
  "name": "Демо: проверка новых функций",
  "version": {
    "data": "",
    "variables": [
      {
        "name": "product_name",
        "title": "Название изделия",
        "type": "string",
        "isInput": true,
        "constraints": []
      },
      {
        "name": "length_mm",
        "title": "Длина (мм)",
        "type": "float",
        "isInput": true,
        "constraints": [
          {
            "name": "положительная_длина",
            "expression": "length_mm > 0",
            "isActive": true
          },
          {
            "name": "разумный_предел",
            "expression": "length_mm < 10000",
            "isActive": true
          }
        ]
      },
      {
        "name": "width_mm",
        "title": "Ширина (мм)",
        "type": "float",
        "isInput": true,
        "constraints": [
          {
            "name": "положительная_ширина",
            "expression": "width_mm > 0",
            "isActive": true
          }
        ]
      },
      {
        "name": "height_mm",
        "title": "Высота (мм)",
        "type": "float",
        "isInput": true,
        "constraints": [
          {
            "name": "положительная_высота",
            "expression": "height_mm > 0",
            "isActive": true
          }
        ]
      },
      {
        "name": "mass_raw_kg",
        "title": "Масса сырая (кг)",
        "type": "float",
        "isInput": true,
        "constraints": [
          {
            "name": "не_ноль",
            "expression": "mass_raw_kg > 0",
            "isActive": true
          },
          {
            "name": "до_тонны",
            "expression": "mass_raw_kg < 1000",
            "isActive": true
          }
        ]
      },
      {
        "name": "efficiency_ratio",
        "title": "Коэффициент эффективности (0..1)",
        "type": "float",
        "isInput": true,
        "constraints": [
          {
            "name": "в_диапазоне_0_1",
            "expression": "clamp(efficiency_ratio, 0, 1) == efficiency_ratio",
            "isActive": true
          }
        ]
      },
      {
        "name": "production_year",
        "title": "Год выпуска",
        "type": "integer",
        "isInput": true,
        "constraints": [
          {
            "name": "разумный_год",
            "expression": "production_year >= 1900 && production_year <= 2100",
            "isActive": true
          }
        ]
      },
      {
        "name": "notes",
        "title": "Заметки (необязательно)",
        "type": "string",
        "isInput": true,
        "constraints": []
      },
      {
        "name": "mass_kg",
        "title": "Масса, округлённая до 50 г",
        "type": "float",
        "isInput": false,
        "expression": "roundStep(mass_raw_kg, 0.05)",
        "constraints": []
      },
      {
        "name": "weight_N",
        "title": "Вес, Н (m · g)",
        "type": "float",
        "isInput": false,
        "expression": "round(mass_kg * g, 2)",
        "constraints": []
      },
      {
        "name": "volume_m3",
        "title": "Объём, м³",
        "type": "float",
        "isInput": false,
        "expression": "round(length_mm * width_mm * height_mm / 1000000000, 4)",
        "constraints": []
      },
      {
        "name": "volume_sci",
        "title": "Объём в научной нотации",
        "type": "string",
        "isInput": false,
        "expression": "scientific(volume_m3, 2)",
        "constraints": []
      },
      {
        "name": "diagonal_mm",
        "title": "Диагональ корпуса, мм",
        "type": "float",
        "isInput": false,
        "expression": "round(sqrt(pow(length_mm, 2) + pow(width_mm, 2) + pow(height_mm, 2)), 1)",
        "constraints": []
      },
      {
        "name": "surface_m2",
        "title": "Площадь поверхности, м²",
        "type": "float",
        "isInput": false,
        "expression": "round(2 * (length_mm * width_mm + length_mm * height_mm + width_mm * height_mm) / 1000000, 3)",
        "constraints": []
      },
      {
        "name": "tilted_height_mm",
        "title": "Высота при наклоне 30°, мм",
        "type": "float",
        "isInput": false,
        "expression": "round(height_mm * cos(pi / 6), 1)",
        "constraints": []
      },
      {
        "name": "efficiency_pct",
        "title": "Эффективность в процентах",
        "type": "string",
        "isInput": false,
        "expression": "percent(efficiency_ratio, 1)",
        "constraints": []
      },
      {
        "name": "clamped_eff",
        "title": "КПД, ограниченный [0; 1]",
        "type": "float",
        "isInput": false,
        "expression": "clamp(efficiency_ratio, 0, 1)",
        "constraints": []
      },
      {
        "name": "temp_norm",
        "title": "Линейная нормализация КПД·100 в [0; 1]",
        "type": "float",
        "isInput": false,
        "expression": "interpolate(efficiency_ratio * 100, 0, 100, 0, 1)",
        "constraints": []
      },
      {
        "name": "mass_display",
        "title": "Масса с разделителями (для текста)",
        "type": "string",
        "isInput": false,
        "expression": "formatNumber(mass_kg, 3)",
        "constraints": []
      },
      {
        "name": "product_slug",
        "title": "Идентификатор для каталога",
        "type": "string",
        "isInput": false,
        "expression": "lower(replace(product_name, \" \", \"_\"))",
        "constraints": []
      }
    ]
  }
}